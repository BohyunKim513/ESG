import os
import re
import numpy as np
import pandas as pd
import networkx as nx
from sklearn.metrics.pairwise import cosine_similarity
from google.colab import drive

# ------------------------------------------------------------------------------------

INPUT_DIR = '/content/drive/MyDrive/논문1/벡터화/vector_csv'
GRAPH_DIR = '/content/drive/MyDrive/논문1/의미네트워크2/NetGraph'
REPORT_DIR = '/content/drive/MyDrive/논문1/의미네트워크2/NetReport'

# 엣지 생성 기준 (상위 3% 유사도)
SIMILARITY_QUANTILE = 0.97

def clean_node_name(s):
    """GraphML(XML) 저장 시 에러를 유발하는 제어 문자를 제거"""
    return re.sub(r'[\x00-\x1F\x7F\n\r\t]', '', str(s))

def main():
    # 1. Mount Google Drive
    drive.mount('/content/drive')

    # 2. Create Output Directories
    os.makedirs(GRAPH_DIR, exist_ok=True)
    os.makedirs(REPORT_DIR, exist_ok=True)

    # 3. Get Target Files
    print(f"Scanning input directory: {INPUT_DIR}")
    file_list = sorted([f for f in os.listdir(INPUT_DIR) if f.endswith('_vec2.csv')])
    total_files = len(file_list)
    
    if total_files == 0:
        print("[-] No valid CSV files found in the directory.")
        return
        
    print(f"Found {total_files} files to process. Starting vector similarity network analysis...\n")

    # 4. Processing Pipeline
    for idx, filename in enumerate(file_list, 1):
        csv_path = os.path.join(INPUT_DIR, filename)
        base_name = filename.replace('_vec2.csv', '')
        graph_path = os.path.join(GRAPH_DIR, f'{base_name}_vecnet.graphml')
        report_path = os.path.join(REPORT_DIR, f'{base_name}_vecnreport.csv')

        print(f"[{idx}/{total_files}] Processing: {base_name}")

        try:
            # [Phase 1] Load Data
            df = pd.read_csv(csv_path, index_col=0)
            terms = df.index.tolist()

            # [Phase 2] Calculate Cosine Similarity
            similarity = cosine_similarity(df.values)

            # Determine Threshold
            sim_vals = similarity[np.triu_indices_from(similarity, k=1)]
            if len(sim_vals) == 0:
                print("  [-] Warning: Not enough terms to calculate similarity. Skipping.")
                continue
                
            threshold = np.quantile(sim_vals, SIMILARITY_QUANTILE)
            print(f"  -> Threshold (Top {100 - SIMILARITY_QUANTILE*100:.0f}%): {threshold:.4f} | Total Terms: {len(terms)}")

            # [Phase 3] Build NetworkX Graph
            G = nx.Graph()
            for i in range(len(terms)):
                G.add_node(terms[i])
                for j in range(i + 1, len(terms)):
                    if similarity[i, j] >= threshold:
                        G.add_edge(terms[i], terms[j], weight=similarity[i, j])

            # Check for complete graph (to prevent excessive computation/useless topology)
            if len(G.nodes) > 0:
                avg_deg = sum(dict(G.degree()).values()) / len(G.nodes)
                if avg_deg >= len(G.nodes) - 1:
                    print("  [!] Warning: Complete graph detected. Skipping analysis to save resources.")
                    continue

            # Clean node names for XML compatibility
            mapping = {node: clean_node_name(node) for node in G.nodes}
            G = nx.relabel_nodes(G, mapping)

            # Save GraphML
            nx.write_graphml(G, graph_path)

            # [Phase 4] Calculate Centrality Metrics
            degree_dict = dict(G.degree())
            weighted_degree = dict(G.degree(weight='weight'))
            
            if len(G.nodes) >= 100:
                betweenness = nx.betweenness_centrality(G, weight='weight', k=100, seed=42)
            elif len(G.nodes) > 1:
                betweenness = nx.betweenness_centrality(G, weight='weight') 
            else:
                print("  [-] Warning: Too few nodes for betweenness centrality.")
                betweenness = {n: None for n in G.nodes}

            report_df = pd.DataFrame({
                'node': list(G.nodes),
                'degree': [degree_dict[n] for n in G.nodes],
                'weighted_degree': [weighted_degree.get(n, 0) for n in G.nodes],
                'betweenness': [betweenness.get(n, 0) for n in G.nodes]
            }).sort_values(by='weighted_degree', ascending=False)

            # Save Report
            report_df.to_csv(report_path, index=False, encoding='utf-8-sig')
            print("  [+] Saved GraphML and Centrality Report successfully.\n")

        except Exception as e:
            print(f"  [X] Error processing {filename}: {e}\n")

    print("All vector similarity network processes completed.")

if __name__ == "__main__":
    main()
